# Generate a secret with bunx @better-auth/cli@latest secret
BETTER_AUTH_SECRET=
SITE_URL=http://localhost:3000
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=
CONVEX_SITE_URL=

# EAS Schema UIDs (register via scripts/register-eas-schemas.js or attest.org)
NEXT_PUBLIC_IDEA_SCHEMA_UID=
NEXT_PUBLIC_REMIX_SCHEMA_UID=
NEXT_PUBLIC_CLAIM_SCHEMA_UID=
NEXT_PUBLIC_COMPLETION_SCHEMA_UID=
NEXT_PUBLIC_BUILD_ENDORSEMENT_SCHEMA_UID=

# MinipadFeeResolver — deploy: npm run deploy-resolver
# Then re-register schemas: RESOLVER_ADDRESS=0x... node scripts/register-eas-schemas.js
RESOLVER_ADDRESS=
# Fee in wei for IDEA, CLAIM, COMPLETION attestations (~$0.01 at $3,000/ETH)
NEXT_PUBLIC_MIN_FEE_WEI=3300000000000
