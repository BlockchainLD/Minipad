    "convex": "^1.27.1",
    "iconoir-react": "^7.11.0",
    "next": "15.5.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "sonner": "^2.0.7",
    "viem": "^2.37.6",
